# =============================================================================
# .env example: copy to .env and fill in your values (.env is gitignored and will not be committed)
# Copy to .env and fill in your values. See README.md for details.
# =============================================================================

# --- WRDS data download (required when pulling WRDS data) ---
# WRDS credentials for downloading data (required for load_data / data_engineering)
WRDS_USERNAME=your_wrds_username

# --- Optional: path overrides (leave unset to use settings.py defaults) ---
# Optional: override paths (defaults: _data, _output, data_manual)
# DATA_DIR=_data
# OUTPUT_DIR=_output
# MANUAL_DATA_DIR=data_manual

# --- Optional: other variables overridable via .env in settings.py ---
# Optional: any ALL_CAPS variable from src/settings.py can be set here or via CLI (e.g. --DATA_DIR=...)
# START_DATE=2020-01-01
# END_DATE=2025-12-31
